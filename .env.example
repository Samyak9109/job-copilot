# Copy to .env before running docker compose in production-like environments.
# The app runs without external API keys in offline/local mode, but JWT_SECRET
# must be changed before exposing it to real users.

JWT_SECRET=replace_with_a_long_random_secret

MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=jobcopilot

# LLM provider: offline | gemini | openrouter | auto
LLM_PROVIDER=offline
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GEMINI_MODEL=gemini-1.5-flash

# Search grounding for interview prep
TAVILY_API_KEY=

# Memory backend: local | cognee
COGNEE_MODE=local
COGNEE_API_KEY=

# Public frontend origin for CORS. Add comma-separated origins if needed.
FRONTEND_ORIGIN=http://localhost:8080

# Upload limit for PDF/DOCX memory ingestion
MAX_UPLOAD_MB=10
