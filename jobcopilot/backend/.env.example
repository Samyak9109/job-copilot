DATABASE_URL=sqlite:///./recallhire.db
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM provider: gemini | openrouter | offline (auto-falls back to offline if no key)
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GEMINI_MODEL=gemini-1.5-flash

# Interview-prep search grounding
TAVILY_API_KEY=

# Memory backend: cognee | local
# cognee -> uses the real Cognee SDK (needs an LLM key for cognify).
# local  -> uses the built-in embedded semantic store (always works, great for demos).
COGNEE_MODE=local
COGNEE_API_KEY=

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173

# Uploads
MAX_UPLOAD_MB=10
